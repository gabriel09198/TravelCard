rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /publicProfiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /decks/{deckId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /collection/{cardId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /wishlist/{cardId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /requests/{requestId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    match /tradeRequests/{requestId} {
      allow read: if request.auth != null
        && (
          resource.data.offerTarget == "geral" ||
          resource.data.targetUserId == request.auth.uid ||
          resource.data.createdByUserId == request.auth.uid
        );

      allow create: if request.auth != null
        && request.resource.data.createdByUserId == request.auth.uid
        && request.resource.data.offerTarget in ["geral", "usuario"]
        && (
          request.resource.data.offerTarget == "geral" ||
          (
            request.resource.data.offerTarget == "usuario" &&
            request.resource.data.targetUserId is string &&
            request.resource.data.targetUserId != ""
          )
        );

      allow update, delete: if request.auth != null
        && resource.data.createdByUserId == request.auth.uid;
    }

    match /crewDirectory/{crewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if request.auth != null
        && (
          chatId == "general" ||
          resource.data.type == "general" ||
          request.auth.uid in resource.data.members ||
          request.auth.uid in resource.data.visibleTo
        );

      allow create: if request.auth != null
        && (
          (request.resource.data.type == "general" && chatId == "general") ||
          (
            request.resource.data.type in ["crew", "private"] &&
            request.auth.uid in request.resource.data.members &&
            request.auth.uid in request.resource.data.visibleTo &&
            request.resource.data.createdBy == request.auth.uid
          )
        );

      allow update: if request.auth != null
        && (
          (chatId == "general" && request.resource.data.type == "general") ||
          request.auth.uid == resource.data.createdBy ||
          (
            resource.data.type == "crew" &&
            resource.data.crewPasswordHash == request.resource.data.crewPasswordHash &&
            request.auth.uid in request.resource.data.members &&
            request.auth.uid in request.resource.data.visibleTo &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["members", "visibleTo", "crewPasswordHash"])
          )
        );

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && (
            chatId == "general" ||
            get(/databases/$(database)/documents/chats/$(chatId)).data.type == "general" ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.visibleTo
          );

        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && (
            chatId == "general" ||
            get(/databases/$(database)/documents/chats/$(chatId)).data.type == "general" ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.visibleTo
          );
      }
    }
  }
}
